{
  "name": "@gigi/openclaw",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin for Gigi P2P network",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "libp2p": "^3.1.6",
    "@libp2p/websockets": "^10.1.6",
    "@libp2p/webtransport": "^6.0.15",
    "@libp2p/mdns": "^12.0.14",
    "@libp2p/kad-dht": "^16.1.6",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0"
  },
  "openclaw": {
    "channel": {
      "id": "gigi",
      "label": "Gigi P2P",
      "selectionLabel": "Gigi P2P Network",
      "blurb": "Connect to Gigi peers via P2P network",
      "aliases": ["p2p"],
      "order": 100
    }
  }
}
