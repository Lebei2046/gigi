{
  "name": "gigi-p2p-bundled",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin for Gigi P2P network",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild index.ts --bundle --platform=node --outfile=dist/bundle.js",
    "build:bundle": "npm run build && npm run bundle",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate-mnemonic": "node --loader ts-node/esm scripts/generate-mnemonic.ts"
  },
  "dependencies": {
    "@gigi/p2p-ts": "file:../../typescript/gigi-p2p-ts",
    "@gigi/request-response-ts": "file:../../typescript/gigi-request-response-ts",
    "@gigi/amp-ts": "file:../../typescript/gigi-amp-ts",
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "openclaw": "^2026.3.22",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": ["./dist/bundle.js"],
    "channel": {
      "id": "gigi-p2p-bundled",
      "label": "Gigi P2P",
      "selectionLabel": "Gigi P2P Network",
      "blurb": "Connect to Gigi peers via P2P network",
      "aliases": ["p2p"],
      "order": 100
    }
  }
}
