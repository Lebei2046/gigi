{
  "name": "gigi-openclaw",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin for Gigi P2P network",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild index.ts --bundle --platform=node --outfile=dist/bundle.js",
    "build:bundle": "npm run build && npm run bundle",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --ext ts,tsx",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "format-all": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"*.json\" \"*.md\" \"docs/**/*.md\" && eslint \"src/**/*.{ts,tsx}\" --ext ts,tsx --fix"
  },
  "dependencies": {
    "@gigi/amp": "workspace:^1.0.0",
    "@gigi/logging": "workspace:^1.0.0",
    "@gigi/p2p": "workspace:^1.0.0",
    "@gigi/request-response": "workspace:^1.0.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "openclaw": "^2026.4.5",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/bundle.js"
    ],
    "channel": {
      "id": "gigi-openclaw",
      "label": "Gigi P2P",
      "selectionLabel": "Gigi P2P Network",
      "blurb": "Connect to Gigi peers via P2P network",
      "aliases": [
        "p2p"
      ],
      "order": 100
    }
  }
}
