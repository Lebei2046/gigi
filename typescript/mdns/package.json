{
  "name": "@gigi/mdns",
  "version": "0.1.0",
  "type": "module",
  "description": "Gigi DNS - Auto-discovery protocol for local networks with nicknames",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@libp2p/interface": "^3.1.0",
    "@libp2p/peer-id": "^6.0.4",
    "@multiformats/multiaddr": "^13.0.1",
    "node-dns-sd": "^1.0.1",
    "@gigi/logging": "workspace:*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.3"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "LOG_LEVEL=silent vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --ext ts,tsx,js,jsx",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --ext ts,tsx,js,jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format-all": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"*.json\" \"*.md\" && eslint \"src/**/*.{ts,tsx,js,jsx}\" --ext ts,tsx,js,jsx --fix"
  }
}
