{
  "name": "@gigi/p2p",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript port of Gigi P2P networking library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@gigi/request-response": "workspace:*",
    "@gigi/mdns": "workspace:*",
    "@gigi/logging": "workspace:*",
    "@gigi/message-types": "workspace:*",
    "@libp2p/autonat": "^3.0.13",
    "@libp2p/circuit-relay-v2": "^2.0.15",
    "@libp2p/crypto": "^5.1.14",
    "@libp2p/gossipsub": "^15.0.14",
    "@libp2p/identify": "^4.0.13",
    "@libp2p/kad-dht": "^16.1.5",
    "@libp2p/noise": "^1.0.1",
    "@libp2p/peer-id": "^6.0.4",
    "@libp2p/peer-id-factory": "^4.2.4",
    "@libp2p/ping": "^3.0.13",
    "@libp2p/tcp": "^11.0.13",
    "@libp2p/websockets": "^10.1.6",
    "@libp2p/webtransport": "^6.0.15",
    "@libp2p/yamux": "^8.0.1",
    "@multiformats/multiaddr": "^13.0.1",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "ed25519": "^0.0.5",
    "err-code": "^3.0.0",
    "libp2p": "^3.1.6",
    "uint8arraylist": "^2.4.0",
    "uint8arrays": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --ext ts,tsx,js,jsx",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --ext ts,tsx,js,jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format-all": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"*.json\" \"*.md\" && eslint \"src/**/*.{ts,tsx,js,jsx}\" --ext ts,tsx,js,jsx --fix"
  }
}
