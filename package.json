{
  "name": "gigi",
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "rust/*",
    "typescript/*"
  ],
  "private": true,
  "scripts": {
    "lint": "pnpm --filter @gigi/amp --filter @gigi/p2p --filter @gigi/request-response --filter @gigi/mdns --filter @gigi/logging --filter p2p-example --filter gigi-openclaw lint",
    "lint:fix": "pnpm --filter @gigi/amp --filter @gigi/p2p --filter @gigi/request-response --filter @gigi/mdns --filter @gigi/logging --filter p2p-example --filter gigi-openclaw lint:fix",
    "format": "pnpm --filter @gigi/amp --filter @gigi/p2p --filter @gigi/request-response --filter @gigi/mdns --filter @gigi/logging --filter p2p-example --filter gigi-openclaw format",
    "format-all": "pnpm --filter @gigi/amp --filter @gigi/p2p --filter @gigi/request-response --filter @gigi/mdns --filter @gigi/logging --filter p2p-example --filter gigi-openclaw format-all",
    "test": "LOG_LEVEL=silent pnpm --filter @gigi/amp --filter @gigi/p2p --filter @gigi/request-response --filter @gigi/mdns --filter @gigi/logging --filter p2p-example test"
  }
}
